{
	"name": "obsidian-project",
	"version": "1.1.1",
	"description": "Project and task management for Obsidian",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build:ci": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"build": "npm run build:ci && npm run deploy",
		"deploy": "node scripts/deploy.mjs",
		"seed:demo": "node scripts/seed-demo.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run"
	},
	"keywords": [],
	"license": "0-BSD",
	"dependencies": {
		"yaml": "^2.8.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.4.0",
		"globals": "^17.6.0",
		"happy-dom": "^18.0.1",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "^3.2.4"
	}
}
